<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>com.github.remotex.RemoteX</id>

  <metadata_license>CC0-1.0</metadata_license>
  <project_license>LicenseRef-proprietary</project_license>

  <name>RemoteX</name>
  <summary>Visual button grid for local and SSH shell commands</summary>

  <description>
    <p>
      RemoteX gives you a Stream Deck-style button grid for launching shell
      commands and SSH commands on remote servers — without touching the
      terminal. Click a button, the command runs.
    </p>
    <p>Free tier features:</p>
    <ul>
      <li>Run local shell commands with a single click</li>
      <li>Up to 3 custom buttons</li>
      <li>Pre-loaded Linux Essentials and Development commands</li>
      <li>Organize buttons by category</li>
      <li>11 interface languages</li>
    </ul>
    <p>Pro features:</p>
    <ul>
      <li>Unlimited custom buttons</li>
      <li>SSH remote machines — unlimited</li>
      <li>Multi-machine command dispatch</li>
      <li>Custom button themes and appearance</li>
      <li>Config backup and restore</li>
      <li>AI integration via MCP protocol (Claude, Cursor, etc.)</li>
    </ul>
  </description>

  <launchable type="desktop-id">com.github.remotex.RemoteX.desktop</launchable>

  <screenshots>
